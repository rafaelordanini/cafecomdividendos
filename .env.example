# ══════════════════════════════════════════
# ValorIA — Variáveis de Ambiente
# Copie para .env.local e preencha os valores
# ══════════════════════════════════════════

# BrAPI — dados de mercado em tempo real
# Cadastre-se gratuitamente em https://brapi.dev
BRAPI_TOKEN=seu_token_brapi_aqui

# Google Gemini — análise por IA
# Crie uma chave em https://aistudio.google.com/apikey
GEMINI_API_KEY=sua_chave_gemini_aqui

# Modelo Gemini (pode trocar conforme disponibilidade)
GEMINI_MODEL=gemini-2.0-flash

# Supabase — cache de análises
# Crie um projeto em https://supabase.com
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_KEY=sua_service_role_key_aqui

# Horas de validade do cache (padrão: 24)
CACHE_TTL_HOURS=24
